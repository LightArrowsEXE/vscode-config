{
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "background.enabled": true,
  "background.editor": {
    "useFront": false,
    "style": {
      "background-position": "right 30px bottom 0.01px",
      "background-repeat": "no-repeat",
      "background-size": "540px auto",
      "opacity": 0.05,
    },
    "images": ["https://i.imgur.com/F0Hof2O.png"],
  },
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.rulers": [0, 72, 120, 158],
  "explorer.confirmDelete": false,
  "files.associations": {
    "*.vpy": "python",
    "*.wob": "json"
  },
  "files.exclude": {
    "**/*.pyc": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.lock": true,
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "git.openRepositoryInParentFolders": "always",
  "python.languageServer": "None",
  "python.locator": "js",
  "python.conda.activation.environmentLocator": "js",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.editorAssociations": {
    "*.mpls": "hexEditor.hexedit",
  },
  "explorer.confirmDragAndDrop": false,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "editor.minimap.enabled": true,
  "markdown.updateLinksOnFileMove.enabled": "always",
  "markdownlint.run": "onSave",
  "git.ignoreLimitWarning": true,
  "window.confirmSaveUntitledWorkspace": false,
  "python.defaultInterpreterPath": "c:\\Users\\light\\AppData\\Local\\Programs\\Python\\Python313\\python.exe",
  "explorer.confirmPasteNative": false,
}
